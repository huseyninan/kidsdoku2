    },
    "**The Goal:** Place each emoji exactly once in every row, column, and 2×2 box!" : {
      "comment" : "A description of the goal of the Sudoku game, presented in bold text.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Das Ziel:** Setze jedes Emoji genau einmal in jede Zeile, Spalte und 2×2 Box!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**El Objetivo:** ¡Coloca cada emoji una vez en cada fila, columna y caja de 2×2!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**L'obiettivo:** Metti ogni emoji esattamente una volta in ogni riga, colonna e riquadro 2×2!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Цель:** Размести каждый смайлик ровно один раз в каждой строке, столбце и квадрате 2×2!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Hedef:** Her emojiyi her satır, sütun ve 2×2 kutuya tam olarak bir kez yerleştir!"
          }
        }
      }
    },
